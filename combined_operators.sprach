# ============================================================
# 21. COMBINED OPERATORS
# ============================================================
geben (5 + 3) und (2 > 1);     # 1 (true)
geben (5 - 5) oder (3 < 5);    # 1 (true)
geben nicht (5 == 3);          # 1 (true)
geben (10 > 5) und (3 < 2);    # 0 (false)

