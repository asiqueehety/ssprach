# ============================================================
# SPRACH COMPREHENSIVE TEST - ALL WORKING FEATURES
# ============================================================

# 1. DATA TYPES & VARIABLES
geben 999;  # Test marker
GANZ intVar = 42;
KOMM doubleVar = 3.14159;
TEXT stringVar = "Hello SPRACH";
ZEICHEN charVar = 'X';

geben intVar;
geben doubleVar;
geben stringVar;
geben charVar;

# 2. ARITHMETIC OPERATIONS
geben 10 + 5;           # 15
geben 20 - 8;           # 12
geben 6 * 7;            # 42
geben 20 / 4;           # 5
geben 17 % 5;           # 2
geben 2 ^ 3;            # 8
geben 2 + 3 * 4;        # 14 (precedence)
geben (2 + 3) * 4;      # 20
geben -5 + 10;          # 5
geben -(3 + 2);         # -5

# 3. COMPARISON OPERATORS
geben 5 == 5;           # 1
geben 5 == 3;           # 0
geben 5 != 3;           # 1
geben 5 < 10;           # 1
geben 5 <= 5;           # 1
geben 5 > 3;            # 1
geben 5 >= 5;           # 1

# 4. LOGICAL OPERATORS
geben 1 und 1;          # 1
geben 1 und 0;          # 0
geben 0 oder 1;         # 1
geben 0 oder 0;         # 0
geben nicht 1;          # 0
geben nicht 0;          # 1
geben (1 und 1) oder 0; # 1

# 5. VARIABLE ASSIGNMENT
GANZ x = 5;
x = 10;
geben x;                # 10

GANZ y = 20;
y = y + 5;
geben y;                # 25

GANZ Name = 100;
GANZ name = 200;
geben Name;             # 100
geben name;             # 200

# 6. IF-ELSE STATEMENTS
GANZ testNum = 15;
wenn (testNum > 10) {
    geben 1;
} sonst {
    geben 0;
}

wenn (testNum < 10) {
    geben 0;
} sonst {
    geben 2;
}

GANZ score = 75;
wenn (score >= 90) {
    geben 1;
} sonst wenn (score >= 80) {
    geben 2;
} sonst wenn (score >= 70) {
    geben 3;
} sonst {
    geben 4;
}

GANZ a = 5;
GANZ b = 10;
wenn (a < b) {
    wenn (a > 0) {
        geben 1;
    }
}

# 7. WHILE LOOPS
GANZ counter = 0;
waehrend (counter < 5) {
    geben counter;      # 0 1 2 3 4
    counter = counter + 1;
}

GANZ sum = 0;
GANZ i = 1;
waehrend (i <= 5) {
    sum = sum + i;      # 1+2+3+4+5 = 15
    i = i + 1;
}
geben sum;              # 15

# 8. FOR LOOPS
fuer (j = 0; j < 5; j = j + 1) {
    geben j;            # 0 1 2 3 4
}

fuer (k = 0; k < 10; k = k + 2) {
    geben k;            # 0 2 4 6 8
}

# 9. ARRAYS
GANZ numbers[] = {10, 20, 30, 40, 50};
geben numbers[0];       # 10
geben numbers[2];       # 30
geben numbers[4];       # 50

fuer (idx = 0; idx < 5; idx = idx + 1) {
    geben numbers[idx]; # 10 20 30 40 50
}

KOMM decimals[] = {1.5, 2.7, 3.2, 4.9};
geben decimals[0];      # 1
geben decimals[2];      # 3

TEXT words[] = {"Hallo", "Welt", "Sprach"};
geben words[0];         # Hallo
geben words[2];         # Sprach

# 10. MATHEMATICAL FUNCTIONS
geben quadrat_wurzel(16);      # 4
geben quadrat_wurzel(25);      # 5

# 11. FIBONACCI SEQUENCE (10 numbers)
GANZ fib_a = 0;
GANZ fib_b = 1;
GANZ fib_count = 0;

waehrend (fib_count < 10) {
    geben fib_a;
    GANZ fib_temp = fib_a + fib_b;
    fib_a = fib_b;
    fib_b = fib_temp;
    fib_count = fib_count + 1;
}

# 12. FACTORIAL (5!)
GANZ factorial = 1;
GANZ fact_n = 5;
fuer (fact_i = 1; fact_i <= fact_n; fact_i = fact_i + 1) {
    factorial = factorial * fact_i;
}
geben factorial;                # 120

# 13. SUM OF ARRAY
GANZ array[] = {5, 10, 15, 20, 25};
GANZ array_sum = 0;
GANZ array_idx = 0;

waehrend (array_idx < 5) {
    array_sum = array_sum + array[array_idx];
    array_idx = array_idx + 1;
}
geben array_sum;                # 75

# 14. FIND MAXIMUM IN ARRAY
GANZ values[] = {3, 7, 2, 9, 1, 5};
GANZ max_val = values[0];
GANZ max_idx = 1;

waehrend (max_idx < 6) {
    wenn (values[max_idx] > max_val) {
        max_val = values[max_idx];
    }
    max_idx = max_idx + 1;
}
geben max_val;                  # 9

# 15. END OF TEST
geben 999;  # Test marker
